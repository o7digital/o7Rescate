---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "O7 Rescue — Mountain & Coastal Safety OS",
  description = "Drones, Garmin y AI para rescate de alto riesgo. Plataforma premium de seguridad y rescate para montaña, parques y playas en México.",
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
